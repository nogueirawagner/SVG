@using SVG.Domain.Entities

@{
    Layout = "_LayoutOperador";
    ViewData["Title"] = "Escala de Plantão";

    var operadoresJson = (string)ViewBag.OperadoresJson;
    var sessoes = (IEnumerable<Sessao>)ViewBag.Sessoes;

    var secaoIdHoje = (int)(ViewBag.SecaoIdHoje ?? 0);
    var secaoIdAmanha = (int)(ViewBag.SecaoIdAmanha ?? 0);
    var secaoIdFantasma = (int)(ViewBag.SecaoIdFantasma ?? 0);

    var plantaoHoje = (string)(ViewBag.PlantaoHoje ?? "");
    var plantaoAmanha = (string)(ViewBag.PlantaoAmanha ?? "");
    var plantaoFantasma = (string)(ViewBag.PlantaoFantasma ?? "");

    var dataHoje = (string)(ViewBag.DataHoje ?? "");
    var dataAmanha = (string)(ViewBag.DataAmanha ?? "");
    var dataFantasma = (string)(ViewBag.DataFantasma ?? "");
}

<div class="container mt-4">
    <h2>Escala de Plantão</h2>
    <hr />

    <div class="row g-3">
        <div class="col-12 col-lg-4">
            <div class="card h-100 border-primary shadow">
                <div class="card-header py-2 bg-primary text-white fw-bold">
                    Hoje (@dataHoje)
                </div>
                <div class="card-body p-3">
                    <div class="mb-2">
                        <strong>Seção:</strong> @plantaoHoje
                    </div>

                    <ul id="listaOperadoresHoje" class="list-group"></ul>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-header py-2">
                    Amanhã (@dataAmanha)
                </div>
                <div class="card-body p-3">
                    <div class="mb-2">
                        <strong>Seção:</strong> @plantaoAmanha
                    </div>

                    <ul id="listaOperadoresAmanha" class="list-group"></ul>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-header py-2">
                    Fantasma (@dataFantasma)
                </div>
                <div class="card-body p-3">
                    <div class="mb-2">
                        <strong>Seção:</strong> @plantaoFantasma
                    </div>

                    <ul id="listaOperadoresFantasma" class="list-group"></ul>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
    </div>
</div>

@section Scripts {
    <script>
        const operadoresData = @Html.Raw(operadoresJson);

        const secaoIdHoje = @secaoIdHoje;
        const secaoIdAmanha = @secaoIdAmanha;
        const secaoIdFantasma = @secaoIdFantasma;

        function renderOperadoresDaSecao(listaId, sessaoId) {
            const lista = document.getElementById(listaId);
            if (!lista) return;

            lista.innerHTML = "";

            if (!sessaoId) {
                const li = document.createElement("li");
                li.className = "list-group-item text-muted";
                li.textContent = "Nenhuma seção definida.";
                lista.appendChild(li);
                return;
            }

            const ops = operadoresData
                .filter(o => o.SessaoID === sessaoId)
                .sort((a, b) => (a.Nome || "").localeCompare(b.Nome || ""));

            if (!ops.length) {
                const li = document.createElement("li");
                li.className = "list-group-item text-muted";
                li.textContent = "Nenhum operador encontrado para esta seção.";
                lista.appendChild(li);
                return;
            }

            ops.forEach(op => {
                const li = document.createElement("li");
                li.className = "list-group-item";
                li.innerHTML = `<strong>${op.Nome}</strong> (${op.Matricula})`;
                lista.appendChild(li);
            });
        }

        document.addEventListener("DOMContentLoaded", function () {
            renderOperadoresDaSecao("listaOperadoresHoje", secaoIdHoje);
            renderOperadoresDaSecao("listaOperadoresAmanha", secaoIdAmanha);
            renderOperadoresDaSecao("listaOperadoresFantasma", secaoIdFantasma);
        });
    </script>
}